{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=travelpax_workforce;"
  },
  "Jwt": {
    "Issuer": "TravelPax.Workforce",
    "Audience": "TravelPax.Workforce.Web",
    "SecretKey": "TravelPax-Workforce-Development-Key-2026-Change-Me",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "App": {
    "FrontendBaseUrl": "http://localhost:5173"
  },
  "Email": {
    "Enabled": true,
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromEmail": "no-reply@travelpax.lk",
    "FromName": "TravelPax Workforce",
    "MaxAttempts": 5,
    "PollIntervalSeconds": 20,
    "BatchSize": 20
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "AllowedHosts": "*"
}
